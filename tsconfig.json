{
  // https://nuxt.com/docs/guide/concepts/typescript
  "files": [],
  // Nuxt drives type-checking through the project references below; these paths
  // exist so the standalone data generators (run via `bun run generators/…`)
  // can resolve the `~~` project-root alias the app code uses.
  "compilerOptions": {
    "paths": {
      "~~": ["."],
      "~~/*": ["./*"]
    }
  },
  "references": [
    { "path": "./.nuxt/tsconfig.app.json" },
    { "path": "./.nuxt/tsconfig.server.json" },
    { "path": "./.nuxt/tsconfig.shared.json" },
    { "path": "./.nuxt/tsconfig.node.json" }
  ]
}
